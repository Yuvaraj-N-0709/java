public class Main {
public static void main(String[]args) {
	 int num1 =100;int num2 =10;int num3 = 10; 
	 int add = num1+num2+num3;
	 int sub = num1-num2-num3;
	 int mul = num1*num2*num3;
	 int div = num1/num2/num3;
	 int mod = num1%num2%num3;
	 System.out.println("add the three number:"+add);
	 System.out.println("sub the three number:"+sub);
	 System.out.println("mul the three number:"+mul);
	 System.out.println("div the three number:"+div);
	 System.out.println("mod the three number:"+mod);
	System.out.println("thank you");
}
}
